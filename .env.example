# MariaDB — 운영은 OCI 도커 내부망(dopacheck-mariadb), 로컬 개발은 SSH 터널 사용 (2026-07-02 OCI 이전)
#   터널: ssh -L 3307:localhost:3307 oci-arm1  → DB_HOST=127.0.0.1 DB_PORT=3307
# 앱 레벨 user_id 필터(RLS 제거, #21)
DB_HOST=localhost
DB_PORT=3306
DB_USER=dopacheck
DB_PASSWORD=your-db-password
DB_NAME=dopamine_check
# 커넥션 풀 크기 (#23) — 미설정 시 기본값 5. Gunicorn 워커수 × DB_POOL_SIZE < MySQL max_connections 확인 필요
DB_POOL_SIZE=5
# 풀 소진 시 커넥션 확보 대기 한도(초) (#71) — 미설정 시 기본값 30. 초과 시 503 응답.
# sync 워커에선 풀이 소진되지 않아 무의미하나, gthread/eventlet 전환 시 무한대기 방지용.
DB_POOL_TIMEOUT=30

# OAuth (관리: 김승현) — 소셜 로그인 (#16)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Google OAuth 콜백 URI — Google Cloud Console에 등록된 주소와 정확히 일치해야 함
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback
KAKAO_CLIENT_ID=your-kakao-client-id
# Kakao OAuth 콜백 URI — Kakao Developers 앱 설정의 Redirect URI와 일치해야 함
KAKAO_REDIRECT_URI=http://localhost:5000/oauth2/code/kakao

# AI (관리: 오영석)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Flask (관리: 김관영)
# 운영 필수 — 미설정 시 공개 기본값으로 fallback되어 세션 위조 위험 (#14)
# 생성 예: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your-flask-secret-key
# production 설정 시 SESSION_COOKIE_SECURE·ProxyFix 활성화 (#44). 로컬은 development 유지
FLASK_ENV=development
# 세션 쿠키 Secure 속성 (#46) — true이거나 FLASK_ENV=production이면 활성화(HTTPS 전용 전송).
# 운영(HTTPS) 배포 시 true 권장. 로컬(http://localhost)에 true로 두면 로그인이 유지되지 않으니 주의.
SESSION_COOKIE_SECURE=false
# 디버그 모드 게이트 — true일 때만 app.run(debug=True) (#44). 운영은 미설정/false
FLASK_DEBUG=false
